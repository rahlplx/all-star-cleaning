---
import { useTranslations } from '@/i18n/translations';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<div class="fixed bottom-0 left-0 right-0 z-sticky border-t border-border bg-white/95 backdrop-blur-md lg:hidden">
  <div class="flex items-center gap-2 px-4 py-2.5">
    <a href="tel:+16135550199" class="flex flex-1 items-center justify-center gap-2 rounded-lg border-2 border-navy px-4 py-2.5 text-sm font-semibold text-navy transition-colors hover:bg-off-white">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {t.cta.callNow}
    </a>
    <a href={`/${locale}/contact`} class="flex flex-1 items-center justify-center rounded-lg bg-teal px-4 py-2.5 text-sm font-semibold text-white shadow-md transition-all hover:bg-teal-dark hover:shadow-lg">{t.cta.freeQuote}</a>
  </div>
</div>
