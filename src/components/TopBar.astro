---
import { useTranslations } from '@/i18n/translations';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<div class="navy-gradient text-white text-xs sm:text-sm" role="complementary" aria-label="Contact information">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-1.5">
    <div class="flex items-center gap-4">
      <span class="flex items-center gap-1.5 opacity-90">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {t.contact.hours}
      </span>
    </div>
    <div class="flex items-center gap-3">
      <a href={`tel:${t.contact.phoneLink}`} class="inline-flex items-center gap-1.5 font-medium transition-colors hover:text-gold">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {t.contact.phone}
      </a>
      <span class="opacity-40" aria-hidden="true">|</span>
      <a href={`mailto:${t.contact.email}`} class="hidden font-medium transition-colors hover:text-gold sm:inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t.contact.email}
      </a>
      <span class="opacity-40 hidden sm:inline" aria-hidden="true">|</span>
      {locale === 'en' ? (
        <a href={Astro.url.pathname.replace(/^\/en/, '/fr')} class="font-medium transition-colors hover:text-gold" lang="fr" hreflang="fr">{locale === 'en' ? 'Français' : 'FR'}</a>
      ) : (
        <a href={Astro.url.pathname.replace(/^\/fr/, '/en')} class="font-medium transition-colors hover:text-gold" lang="en" hreflang="en">{locale === 'fr' ? 'English' : 'EN'}</a>
      )}
    </div>
  </div>
</div>
