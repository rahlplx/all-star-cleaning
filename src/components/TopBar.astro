---
import { useTranslations } from '@/i18n/translations';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<div class="navy-gradient text-white text-xs sm:text-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-1.5">
    <div class="hidden items-center gap-4 sm:flex">
      <span class="opacity-90">{t.footer.weekdayHours}</span>
      <span class="opacity-60">|</span>
      <span class="opacity-90">{t.footer.weekendHours}</span>
    </div>
    <span class="sm:hidden opacity-90">{t.footer.weekdayHours}</span>
    <div class="flex items-center gap-3">
      <a href="tel:+16135550199" class="inline-flex items-center gap-1.5 font-medium transition-colors hover:text-gold">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (613) 555-0199
      </a>
      <span class="opacity-40">|</span>
      {locale === 'en' ? (
        <a href={Astro.url.pathname.replace(/^\/en/, '/fr')} class="font-medium transition-colors hover:text-gold" lang="fr" hreflang="fr">FR</a>
      ) : (
        <a href={Astro.url.pathname.replace(/^\/fr/, '/en')} class="font-medium transition-colors hover:text-gold" lang="en" hreflang="en">EN</a>
      )}
    </div>
  </div>
</div>
