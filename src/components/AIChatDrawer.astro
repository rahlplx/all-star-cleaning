---
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const isFr = locale === 'fr';
---
<!-- AI Chat Drawer -->
<div
  id="ai-chat-drawer"
  role="dialog"
  aria-modal="true"
  aria-label={isFr ? 'Assistant IA' : 'AI Assistant'}
  aria-hidden="true"
  class="fixed inset-y-0 right-0 z-[10000] flex w-full max-w-sm flex-col bg-canvas shadow-2xl translate-x-full transition-transform duration-300 ease-in-out"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <!-- Header -->
  <div class="flex items-center justify-between border-b border-hairline px-4 py-3 shrink-0">
    <div class="flex items-center gap-2">
      <div class="flex h-7 w-7 items-center justify-center rounded-md bg-brand text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </div>
      <span class="text-sm font-medium text-ink">{isFr ? 'Assistant All Star' : 'Ask All Star AI'}</span>
    </div>
    <button
      id="close-ai-chat"
      type="button"
      class="touch-target flex h-8 w-8 items-center justify-center rounded-md text-ink/50 transition-colors hover:bg-surface-soft hover:text-ink focus-visible:ring-2 focus-visible:ring-brand"
      aria-label={isFr ? 'Fermer le chat' : 'Close chat'}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Messages thread -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3">
    <!-- Welcome message -->
    <div class="flex gap-2">
      <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand text-white mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </div>
      <div class="rounded-lg rounded-tl-none bg-surface-soft px-3 py-2.5 text-sm text-ink max-w-[85%]">
        {isFr
          ? "Bonjour ! Je suis l'assistant IA d'All Star Cleaning. Que puis-je faire pour vous ?"
          : "Hi! I'm All Star Cleaning's AI assistant. How can I help you today?"}
      </div>
    </div>
    <!-- Suggestion chips -->
    <div class="flex flex-wrap gap-2 pl-8">
      <button type="button" class="chat-suggestion rounded-full border border-hairline bg-canvas px-3 py-1.5 text-xs text-ink transition-colors hover:border-brand hover:text-brand focus-visible:ring-2 focus-visible:ring-brand">
        {isFr ? 'Quels services offrez-vous ?' : 'What services do you offer?'}
      </button>
      <button type="button" class="chat-suggestion rounded-full border border-hairline bg-canvas px-3 py-1.5 text-xs text-ink transition-colors hover:border-brand hover:text-brand focus-visible:ring-2 focus-visible:ring-brand">
        {isFr ? 'Secteurs desservis ?' : 'Areas you serve?'}
      </button>
      <button type="button" class="chat-suggestion rounded-full border border-hairline bg-canvas px-3 py-1.5 text-xs text-ink transition-colors hover:border-brand hover:text-brand focus-visible:ring-2 focus-visible:ring-brand">
        {isFr ? 'Obtenir un devis' : 'Get a quote'}
      </button>
    </div>
  </div>

  <!-- Input -->
  <div class="border-t border-hairline p-3 shrink-0">
    <form id="chat-form" class="flex gap-2">
      <input
        type="text"
        id="chat-input"
        name="message"
        placeholder={isFr ? 'Posez une question…' : 'Ask about services…'}
        autocomplete="off"
        class="flex-1 rounded-md border border-hairline bg-canvas px-3 py-2 text-sm text-ink placeholder:text-ink/40 focus:border-brand focus:outline-none focus-visible:ring-2 focus-visible:ring-brand"
        aria-label={isFr ? 'Message' : 'Message'}
      />
      <button
        type="submit"
        id="chat-submit"
        class="touch-target flex items-center justify-center rounded-md bg-brand px-3 py-2 text-white transition-colors hover:bg-brand-active focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-1 disabled:opacity-50"
        aria-label={isFr ? 'Envoyer' : 'Send'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
  </div>
</div>

<!-- Overlay -->
<div id="chat-overlay" class="fixed inset-0 z-[9999] bg-ink/40 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>

<script define:vars={{ locale }}>
  const drawer = document.getElementById('ai-chat-drawer');
  const overlay = document.getElementById('chat-overlay');
  const closeBtn = document.getElementById('close-ai-chat');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const messagesEl = document.getElementById('chat-messages');
  const submitBtn = document.getElementById('chat-submit');

  let history = [];
  let isOpen = false;

  function openDrawer() {
    if (isOpen) return;
    isOpen = true;
    drawer?.classList.remove('translate-x-full');
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    drawer?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    input?.focus();
  }

  function closeDrawer() {
    if (!isOpen) return;
    isOpen = false;
    drawer?.classList.add('translate-x-full');
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    drawer?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.addEventListener('openAIChat', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  drawer?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeDrawer(); return; }
    if (e.key === 'Tab') {
      const focusable = drawer.querySelectorAll('a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  });

  // Suggestion chips
  messagesEl?.querySelectorAll('.chat-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      if (input) input.value = btn.textContent?.trim() || '';
      sendMessage();
    });
  });

  function appendBubble(role, content) {
    const isAI = role === 'assistant';
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2' + (isAI ? '' : ' justify-end');

    if (isAI) {
      wrapper.innerHTML = `
        <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand text-white mt-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        </div>
        <div class="rounded-lg rounded-tl-none bg-surface-soft px-3 py-2.5 text-sm text-ink max-w-[85%]">${escapeHtml(content)}</div>
      `;
    } else {
      wrapper.innerHTML = `
        <div class="rounded-lg rounded-tr-none bg-brand px-3 py-2.5 text-sm text-white max-w-[85%]">${escapeHtml(content)}</div>
      `;
    }
    messagesEl?.appendChild(wrapper);
    messagesEl?.scrollTo({ top: messagesEl.scrollHeight, behavior: 'smooth' });
  }

  function appendCard(data) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2';

    let cardHtml = '';

    if (data.type === 'service_card') {
      cardHtml = `
        <div class="rounded-lg border border-hairline bg-canvas p-3 max-w-[85%]">
          <p class="text-[11px] font-medium uppercase tracking-wider text-brand mb-1">Service</p>
          <p class="text-sm font-semibold text-ink">${escapeHtml(data.name || '')}</p>
          <p class="mt-1 text-xs text-ink/70 leading-relaxed">${escapeHtml(data.description || '')}</p>
          ${data.url ? `<a href="${escapeHtml(data.url)}" class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-brand hover:underline">Learn more <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg></a>` : ''}
        </div>
      `;
    } else if (data.type === 'location_list') {
      const locs = (data.locations || []).map(l => `<a href="${escapeHtml(l.url || '#')}" class="shrink-0 rounded-full border border-hairline bg-canvas px-3 py-1.5 text-xs text-ink hover:border-brand hover:text-brand transition-colors">${escapeHtml(l.name || '')}</a>`).join('');
      cardHtml = `
        <div class="max-w-[85%]">
          <p class="text-xs text-ink/60 mb-2">${locale === 'fr' ? 'Zones desservies' : 'Areas we serve'}:</p>
          <div class="flex flex-wrap gap-1.5">${locs}</div>
        </div>
      `;
    } else if (data.type === 'contact_card') {
      cardHtml = `
        <div class="rounded-lg border border-hairline bg-canvas p-3 max-w-[85%]">
          <p class="text-[11px] font-medium uppercase tracking-wider text-brand mb-2">Contact</p>
          ${data.phone ? `<a href="tel:${escapeHtml(data.phone)}" class="flex items-center gap-2 text-sm text-ink hover:text-brand transition-colors"><svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>${escapeHtml(data.phone)}</a>` : ''}
          ${data.email ? `<a href="mailto:${escapeHtml(data.email)}" class="mt-1 flex items-center gap-2 text-sm text-ink hover:text-brand transition-colors"><svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>${escapeHtml(data.email)}</a>` : ''}
          ${data.cta ? `<a href="/${locale}/contact" class="mt-3 block rounded-md bg-brand px-3 py-2 text-center text-xs font-medium text-white hover:bg-brand-active transition-colors">${escapeHtml(data.cta)}</a>` : ''}
        </div>
      `;
    } else {
      appendBubble('assistant', data.content || '');
      return;
    }

    wrapper.innerHTML = `
      <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand text-white mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </div>
      ${cardHtml}
    `;
    messagesEl?.appendChild(wrapper);
    messagesEl?.scrollTo({ top: messagesEl.scrollHeight, behavior: 'smooth' });
  }

  function appendTyping() {
    const el = document.createElement('div');
    el.id = 'chat-typing';
    el.className = 'flex gap-2';
    el.innerHTML = `
      <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand text-white mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
      </div>
      <div class="rounded-lg rounded-tl-none bg-surface-soft px-4 py-3">
        <div class="flex gap-1 items-center">
          <span class="h-2 w-2 rounded-full bg-ink/30 animate-bounce" style="animation-delay:0ms"></span>
          <span class="h-2 w-2 rounded-full bg-ink/30 animate-bounce" style="animation-delay:150ms"></span>
          <span class="h-2 w-2 rounded-full bg-ink/30 animate-bounce" style="animation-delay:300ms"></span>
        </div>
      </div>
    `;
    messagesEl?.appendChild(el);
    messagesEl?.scrollTo({ top: messagesEl.scrollHeight, behavior: 'smooth' });
  }

  function removeTyping() {
    document.getElementById('chat-typing')?.remove();
  }

  function escapeHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  async function sendMessage() {
    const msg = input?.value.trim();
    if (!msg) return;

    if (input) input.value = '';
    if (submitBtn) submitBtn.disabled = true;

    appendBubble('user', msg);
    appendTyping();

    history.push({ role: 'user', content: msg });

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history: history.slice(-6), locale }),
      });

      removeTyping();

      if (!res.ok) throw new Error('Network error');

      const data = await res.json();
      history.push({ role: 'assistant', content: data.content || JSON.stringify(data) });
      appendCard(data);
    } catch {
      removeTyping();
      appendBubble('assistant', locale === 'fr'
        ? "Désolé, je n'ai pas pu obtenir de réponse. Veuillez appeler le (613) 314-3300."
        : "Sorry, I couldn't get a response. Please call us at (613) 314-3300.");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      input?.focus();
    }
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    sendMessage();
  });
</script>
