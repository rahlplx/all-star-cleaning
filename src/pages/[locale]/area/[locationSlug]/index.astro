---
// Location hub page — lists all services available in a given location
// Generates 44 locations × 2 locales = 88 pages
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceBadge from '@/components/ServiceBadge.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    locations.map((location) => ({
      params: { locale, locationSlug: location.slug },
      props: { location, locale: locale as 'en' | 'fr' },
    }))
  );
}

const { location, locale } = Astro.props;
const isFr = locale === 'fr';
const t = useTranslations(locale);
const altLocale = isFr ? 'en' : 'fr';

const breadcrumbs: BreadcrumbItem[] = [
  { label: t.nav.home, frLabel: t.nav.home, href: `/${locale}` },
  { label: t.nav.area, frLabel: t.nav.area, href: `/${locale}/area` },
  { label: location.name, frLabel: location.frName, href: `/${locale}/area/${location.slug}` },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);

const heroTitle = isFr
  ? `Services de Nettoyage à ${location.frName}`
  : `Cleaning Services in ${location.name}`;
const heroSubtitle = isFr
  ? `Services professionnels de nettoyage extérieur à ${location.frName} et les environs. Vitres, gouttières, lavage sous pression, revêtement et déneigement.`
  : `Professional exterior cleaning services in ${location.name} and surrounding areas. Window, gutter, pressure washing, siding & snow removal.`;
---

<PageLayout
  title={isFr ? `Services de Nettoyage à ${location.frName} Ottawa | All Star Cleaning` : `Cleaning Services in ${location.name} Ottawa | All Star Cleaning`}
  description={isFr
    ? `Services de nettoyage extérieur professionnels à ${location.frName}, Ottawa. Vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuit.`
    : `Professional exterior cleaning services in ${location.name}, Ottawa. Window, gutter, pressure washing, siding cleaning & snow removal. Free quote.`}
  locale={locale}
  ogImage="https://allstarcleaning.ca/og-default.jpg"
  breadcrumbs={breadcrumbs}
  heroTitle={heroTitle}
  heroSubtitle={heroSubtitle}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/area/${location.slug}/` }]}
  schema={[breadcrumbSchema]}
>
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
      <!-- Area Context -->
      <div class="mt-10 rounded-xl border border-border bg-card p-6">
        <h2 class="font-heading text-2xl font-bold text-midnight-indigo">
          {isFr ? `Nettoyage Extérieur à ${location.frName}` : `Exterior Cleaning in ${location.name}`}
        </h2>
        <p class="mt-2 measure text-muted-foreground leading-relaxed">
          {isFr
            ? `Nous sommes fiers de desservir ${location.frName} et les quartiers environnants de la région d'Ottawa. Notre équipe locale connaît bien les besoins uniques des propriétés dans cette zone ${location.area} d'Ottawa. Appelez-nous au ${siteSettings.phone} pour un devis gratuit.`
            : `We proudly serve ${location.name} and surrounding neighbourhoods in the Ottawa region. Our local team understands the unique needs of properties in this ${location.area} Ottawa zone. Call us at ${siteSettings.phone} for a free quote.`}
        </p>
      </div>

      <!-- Map for location -->
      <div class="mt-10 rounded-xl border border-border overflow-hidden">
        <iframe
          src={`https://www.google.com/maps?q=${location.coordinates.lat},${location.coordinates.lng}&z=13&output=embed`}
          width="100%"
          height="300"
          class="border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={isFr ? `Carte de ${location.frName}` : `Map of ${location.name}`}
        ></iframe>
      </div>

      <!-- All Services Grid -->
      <h2 class="font-heading heading-card font-bold text-midnight-indigo">
        {isFr ? 'Nos Services à' : 'Our Services in'} {isFr ? location.frName : location.name}
      </h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {services.map((service, i) => (
          <a
            href={`/${locale}/area/${location.slug}/${service.slug}`}
            class:list={[
              'touch-target group rounded-xl border border-border bg-card p-5 transition-colors duration-200 hover:border-midnight-indigo/30 hover:shadow-md hover-lift focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2',
              i === 0 ? 'sm:col-span-2 border-midnight-indigo/20 bg-midnight-indigo/5' : '',
            ]}
          >
            <h3 class="font-heading text-lg font-semibold text-navy group-hover:text-midnight-indigo">
              {isFr ? service.frName : service.name}
            </h3>
            <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
              {isFr ? service.frDescription : service.description}
            </p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-midnight-indigo">
              {t.ui.learnMore}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Neighbouring Areas -->
      {location.neighbours.length > 0 && (
        <div class="mt-10">
        <h2 class="font-heading heading-card font-bold text-midnight-indigo">
            {isFr ? 'Quartiers avoisinants' : 'Nearby Areas'}
          </h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {location.neighbours.map((neighbour) => {
              const loc = locations.find((l) => l.slug === neighbour);
              return loc ? (
                <ServiceBadge key={loc.slug} label={isFr ? loc.frName : loc.name} href={`/${locale}/area/${loc.slug}`} variant="teal" />
              ) : null;
            })}
          </div>
        </div>
      )}
    </div>

    <!-- Sidebar CTA -->
    <div class="lg:col-span-1">
      <SidebarCTA
        heading={t.cta.freeQuote}
        description={isFr ? `Besoin de services de nettoyage à ${location.frName}? Contactez-nous pour un devis gratuit.` : `Need cleaning services in ${location.name}? Contact us for a free quote.`}
        ctaText={t.cta.freeQuote}
        contactHref={`/${locale}/contact?area=${location.slug}`}
        responseTimeText={t.servicesPage.noObligation24h}
        phoneLink={siteSettings.phoneLink}
        phone={siteSettings.phone}
      />
    </div>
  </div>
</div>
</PageLayout>
