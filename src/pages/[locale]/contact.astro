---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/i18n/translations';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
---
<BaseLayout
  title={isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa'}
  description={isFr ? 'Contactez All Star Cleaning pour un devis gratuit. Appelez le (613) 314-3300 ou remplissez notre formulaire en ligne.' : 'Contact All Star Cleaning for a free quote. Call (613) 314-3300 or fill out our online form.'}
  locale={locale}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/contact/` }]}
>
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4">
      <h1 class="slide-up font-heading text-4xl font-bold text-navy md:text-5xl">{isFr ? 'Contactez-Nous' : 'Contact Us'}</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted-foreground">{isFr ? "Obtenez un devis gratuit pour tous vos besoins en nettoyage extérieur." : 'Get a free quote for all your exterior cleaning needs.'}</p>

      <div class="mt-10 grid gap-10 lg:grid-cols-5">
        <!-- Contact Info -->
        <div class="space-y-6 md:col-span-2 lg:col-span-2">
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Appelez-Nous' : 'Call Us'}</h2>
            <a href="tel:+16133143300" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-text hover:text-teal-dark touch-target transition-colors">(613) 314-3300</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Courriel' : 'Email'}</h2>
            <a href="mailto:hello@allstarcleaning.ca" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-text hover:text-teal-dark touch-target transition-colors">hello@allstarcleaning.ca</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Adresse' : 'Address'}</h2>
            <p class="mt-2 text-muted-foreground">{t.contact.address}</p>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Heures' : 'Hours'}</h2>
            <p class="mt-2 text-muted-foreground">{t.contact.hours}</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm md:col-span-3 lg:col-span-3">
          <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Demande de Devis Gratuit' : 'Request a Free Quote'}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.' : 'Fill out the form below and we\'ll get back to you quickly.'}</p>

          <form id="contact-form" class="mt-6 space-y-4" novalidate>
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-navy">{isFr ? 'Nom' : 'Name'} <span class="text-destructive" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name" aria-describedby="name-hint" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? 'Votre nom' : 'Your name'} />
                <p id="name-hint" class="sr-only">{isFr ? 'Le nom est requis' : 'Name is required'}</p>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-navy">{isFr ? 'Téléphone' : 'Phone'} <span class="text-destructive" aria-hidden="true">*</span></label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel" aria-describedby="phone-hint" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? '(613) 000-0000' : '(613) 000-0000'} />
                <p id="phone-hint" class="sr-only">{isFr ? 'Le numéro de téléphone est requis' : 'Phone number is required'}</p>
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy">{isFr ? 'Courriel' : 'Email'}</label>
              <input type="email" id="email" name="email" autocomplete="email" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? 'votre@courriel.ca' : 'your@email.ca'} />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-navy">{isFr ? 'Service souhaité' : 'Service Needed'}</label>
              <select id="service" name="service" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-2.5 text-sm text-navy transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20">
                <option value="">{isFr ? 'Sélectionnez un service' : 'Select a service'}</option>
                <option value="window-cleaning">{isFr ? 'Nettoyage de Vitres' : 'Window Cleaning'}</option>
                <option value="gutter-cleaning">{isFr ? 'Nettoyage de Gouttières' : 'Gutter Cleaning'}</option>
                <option value="pressure-washing">{isFr ? 'Lavage sous Pression' : 'Pressure Washing'}</option>
                <option value="siding-cleaning">{isFr ? 'Nettoyage de Revêtement' : 'Siding Cleaning'}</option>
                <option value="snow-removal">{isFr ? 'Dénéigement' : 'Snow Removal'}</option>
                <option value="other">{isFr ? 'Autre' : 'Other'}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy">{isFr ? 'Message' : 'Message'}</label>
              <textarea id="message" name="message" rows="4" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20 resize-y" placeholder={isFr ? 'Décrivez vos besoins en nettoyage...' : 'Describe your cleaning needs...'}></textarea>
            </div>
            <button type="submit" class="w-full rounded-full bg-teal-text px-6 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-teal-dark hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-text active:scale-[0.98] touch-target sm:w-auto">
              {isFr ? 'Envoyer la Demande' : 'Send Request'}
            </button>
          </form>
          <div id="form-success" role="alert" aria-live="polite" class="hidden rounded-lg bg-green/10 border border-green/20 p-4 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p class="mt-2 font-semibold text-navy">{isFr ? 'Demande envoyée !' : 'Request sent!'}</p>
            <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Nous vous répondrons dans les plus brefs délais.' : "We'll get back to you shortly."}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
<script>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('form-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // Custom validation with accessible error messages
      let isValid = true;
      const requiredFields = form.querySelectorAll('[required]');
      requiredFields.forEach((field) => {
        field.classList.remove('field-error');
        const hint = field.closest('div')?.querySelector('.field-error-message');
        if (hint) hint.remove();
        if (!field.validity.valid) {
          isValid = false;
          field.classList.add('field-error');
          field.setAttribute('aria-invalid', 'true');
          const msg = document.createElement('p');
          msg.className = 'field-error-message';
          msg.setAttribute('role', 'alert');
          msg.textContent = field.validity.valueMissing
            ? (field.labels?.[0]?.textContent?.replace(' *', '') + ' is required')
            : field.validationMessage;
          field.closest('div')?.appendChild(msg);
        } else {
          field.removeAttribute('aria-invalid');
        }
      });
      if (!isValid) {
        const firstError = form.querySelector('.field-error');
        firstError?.focus();
        return;
      }
      // In production, replace with actual form submission (e.g., Formspree, Netlify Forms)
      form.classList.add('hidden');
      success.classList.remove('hidden');
      // Move focus to success message for screen readers
      success.setAttribute('tabindex', '-1');
      success.focus();
    });
    // Clear error on input
    form.querySelectorAll('[required]').forEach((field) => {
      field.addEventListener('input', () => {
        field.classList.remove('field-error');
        field.removeAttribute('aria-invalid');
        const hint = field.closest('div')?.querySelector('.field-error-message');
        if (hint) hint.remove();
      });
    });
  }
</script>
</BaseLayout>
