---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/i18n/translations';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
---
<BaseLayout
  title={isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa'}
  description={isFr ? 'Contactez All Star Cleaning pour un devis gratuit. Appelez le (613) 314-3300 ou remplissez notre formulaire en ligne.' : 'Contact All Star Cleaning for a free quote. Call (613) 314-3300 or fill out our online form.'}
  locale={locale}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/contact/` }]}
>
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4">
      <h1 class="font-heading text-4xl font-bold text-navy md:text-5xl">{isFr ? 'Contactez-Nous' : 'Contact Us'}</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">{isFr ? "Obtenez un devis gratuit pour tous vos besoins en nettoyage extérieur." : 'Get a free quote for all your exterior cleaning needs.'}</p>
      
      <div class="mt-10 grid gap-10 md:grid-cols-5">
        <!-- Contact Info -->
        <div class="md:col-span-2 space-y-6">
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Appelez-Nous' : 'Call Us'}</h2>
            <a href="tel:+16133143300" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-dark hover:text-navy touch-target">(613) 314-3300</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Courriel' : 'Email'}</h2>
            <a href="mailto:hello@allstarcleaning.ca" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-dark hover:text-navy touch-target">hello@allstarcleaning.ca</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Adresse' : 'Address'}</h2>
            <p class="mt-2 text-muted">{t.contact.address}</p>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Heures' : 'Hours'}</h2>
            <p class="mt-2 text-muted">{t.contact.hours}</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="rounded-xl border border-border bg-card p-6 shadow-sm md:col-span-3">
          <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Demande de Devis Gratuit' : 'Request a Free Quote'}</h2>
          <p class="mt-1 text-sm text-muted">{isFr ? 'Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.' : 'Fill out the form below and we\'ll get back to you quickly.'}</p>
          
          <form action={`mailto:hello@allstarcleaning.ca`} method="POST" enctype="text/plain" class="mt-6 space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-navy">{isFr ? 'Nom' : 'Name'} <span class="text-destructive">*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name" class="mt-1 block w-full rounded-md border border-border bg-off-white px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/20" placeholder={isFr ? 'Votre nom' : 'Your name'} />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-navy">{isFr ? 'Téléphone' : 'Phone'} <span class="text-destructive">*</span></label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel" class="mt-1 block w-full rounded-md border border-border bg-off-white px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/20" placeholder={isFr ? '(613) 000-0000' : '(613) 000-0000'} />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy">{isFr ? 'Courriel' : 'Email'}</label>
              <input type="email" id="email" name="email" autocomplete="email" class="mt-1 block w-full rounded-md border border-border bg-off-white px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/20" placeholder={isFr ? 'votre@courriel.ca' : 'your@email.ca'} />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-navy">{isFr ? 'Service souhaité' : 'Service Needed'}</label>
              <select id="service" name="service" class="mt-1 block w-full rounded-md border border-border bg-off-white px-4 py-2.5 text-sm text-navy transition-colors focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/20">
                <option value="">{isFr ? 'Sélectionnez un service' : 'Select a service'}</option>
                <option value="window-cleaning">{isFr ? 'Nettoyage de Vitres' : 'Window Cleaning'}</option>
                <option value="gutter-cleaning">{isFr ? 'Nettoyage de Gouttières' : 'Gutter Cleaning'}</option>
                <option value="pressure-washing">{isFr ? 'Lavage sous Pression' : 'Pressure Washing'}</option>
                <option value="siding-cleaning">{isFr ? 'Nettoyage de Revêtement' : 'Siding Cleaning'}</option>
                <option value="snow-removal">{isFr ? 'Dénéigement' : 'Snow Removal'}</option>
                <option value="other">{isFr ? 'Autre' : 'Other'}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy">{isFr ? 'Message' : 'Message'}</label>
              <textarea id="message" name="message" rows="4" class="mt-1 block w-full rounded-md border border-border bg-off-white px-4 py-2.5 text-sm text-navy placeholder:text-muted-foreground transition-colors focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/20 resize-y" placeholder={isFr ? 'Décrivez vos besoins en nettoyage...' : 'Describe your cleaning needs...'}></textarea>
            </div>
            <button type="submit" class="w-full rounded-full bg-teal-dark px-6 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-navy hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal touch-target sm:w-auto">
              {isFr ? 'Envoyer la Demande' : 'Send Request'}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
