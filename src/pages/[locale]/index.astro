---
// Dynamic locale homepage — Astro v6
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';
import { useTranslations } from '@/i18n/translations';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const usps = [
  { icon: 'shield', title: t.usps.expertise.title, description: t.usps.expertise.description },
  { icon: 'sparkles', title: t.usps.equipment.title, description: t.usps.equipment.description },
  { icon: 'check-circle', title: t.usps.guarantee.title, description: t.usps.guarantee.description },
];
---

<BaseLayout
  title={isFr ? 'All Star Cleaning Ottawa | Nettoyage de Vitres, Gouttières et Lavage sous Pression' : 'All Star Cleaning Ottawa | Window, Gutter & Pressure Washing'}
  description={isFr ? 'Service de nettoyage de confiance à Ottawa. Nettoyage de vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuits.' : "Ottawa's trusted cleaning service. Window cleaning, gutter cleaning, pressure washing, siding cleaning & snow removal. Free quotes — residential & commercial."}
  locale={locale}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/` }]}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden navy-gradient py-20 text-white sm:py-28 lg:py-36">
    <div class="relative z-10 mx-auto max-w-7xl px-4 text-center">
      <h1 class="font-heading text-4xl font-bold sm:text-5xl lg:text-6xl xl:text-7xl">
        {isFr ? <>Nettoyage Extérieur<br /><span class="text-teal-light">de Confiance à Ottawa</span></> : <>Ottawa's Trusted<br /><span class="text-teal-light">Exterior Cleaning</span></>}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/80 sm:text-xl">
        {isFr ? "Nettoyage professionnel de vitres, gouttières, lavage sous pression, revêtement et déneigement dans la région d'Ottawa." : 'Professional window cleaning, gutter cleaning, pressure washing, siding cleaning, and snow removal across the Ottawa region.'}
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={`/${locale}/contact`} class="inline-flex items-center rounded-full bg-teal-dark px-8 py-3.5 text-lg font-semibold text-white shadow-lg transition-all hover:bg-navy hover:shadow-xl">
          {t.cta.freeQuote}
        </a>
        <a href={`tel:${t.contact.phoneLink}`} class="inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-3.5 text-lg font-semibold text-white transition-all hover:border-white/60 hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {t.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- USP Section -->
  <section class="py-16 sm:py-20 bg-off-white">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid gap-8 sm:grid-cols-3">
        {usps.map((usp) => (
          <div class="rounded-xl bg-white p-6 shadow-sm border border-border text-center sm:text-left">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-teal/10 text-teal sm:mx-0">
              {usp.icon === 'shield' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {usp.icon === 'sparkles' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
              )}
              {usp.icon === 'check-circle' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              )}
            </div>
            <h3 class="font-heading text-lg font-semibold text-navy">{usp.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{usp.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-navy sm:text-4xl">{isFr ? 'Nos Services' : 'Our Services'}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-muted">{isFr ? "Des fenêtres étincelantes aux allées déneigées, nous couvrons tout Ottawa." : "From sparkling windows to snow-free driveways, we've got Ottawa covered."}</p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a href={`/${locale}/services/${service.slug}`} class="group rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:border-teal/30 hover:shadow-md">
            <h3 class="font-heading text-xl font-semibold text-navy group-hover:text-teal">{isFr ? service.frName : service.name}</h3>
            <p class="mt-2 text-sm text-muted line-clamp-3">{isFr ? service.frDescription : service.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-teal-dark">
              {isFr ? 'En savoir plus' : 'Learn more'}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="navy-gradient py-16 text-white sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="font-heading text-3xl font-bold sm:text-4xl">{isFr ? 'Prêt à Commencer?' : 'Ready to Get Started?'}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-white/80">{isFr ? 'Contactez-nous dès aujourd\'hui pour un devis gratuit. Nous sommes ouverts 7 jours par semaine!' : 'Contact us today for a free quote. We\'re open 7 days a week!'}</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={`/${locale}/contact`} class="inline-flex items-center rounded-full bg-teal-dark px-8 py-3.5 text-lg font-semibold text-white shadow-lg transition-all hover:bg-navy hover:shadow-xl">
          {t.cta.freeQuote}
        </a>
        <a href={`tel:${t.contact.phoneLink}`} class="inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-3.5 text-lg font-semibold text-white transition-all hover:border-white/60 hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {t.contact.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
