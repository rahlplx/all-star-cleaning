---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';
import { useTranslations } from '@/i18n/translations';
import { getHowToSchema, getBreadcrumbSchema } from '@/seo';
import homepageData from '@/content/homepage.json';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const howtoSchema = getHowToSchema(locale);
const homeBreadcrumbSchema = getBreadcrumbSchema([
  { label: t.nav.home, frLabel: t.nav.home, href: `/${locale}` },
], locale);

const cms = homepageData;
const s = siteSettings;

const serviceObjectPosition: Record<string, string> = {
  'window-cleaning':  'object-center',
  'gutter-cleaning':  'object-[center_30%]',
  'pressure-washing': 'object-center',
  'siding-cleaning':  'object-center',
  'snow-removal':     'object-center',
};
---

<BaseLayout
  title={isFr ? 'All Star Cleaning Ottawa | Nettoyage de Vitres, Gouttières et Lavage sous Pression' : 'All Star Cleaning Ottawa | Window, Gutter & Pressure Washing'}
  description={isFr ? 'Service de nettoyage de confiance à Ottawa. Nettoyage de vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuits.' : "Ottawa's trusted cleaning service. Window cleaning, gutter cleaning, pressure washing, siding cleaning & snow removal. Free quotes: residential & commercial."}
  locale={locale}
  ogImage="https://allstarcleaning.ca/og-default.jpg"
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/` }]}
  schema={[howtoSchema, homeBreadcrumbSchema]}
>

  <!-- ============================================================ -->
  <!-- HERO — Video (desktop) / Poster (mobile), bold editorial -->
  <!-- ============================================================ -->
  <section
    aria-label={isFr ? 'Accueil' : 'Homepage hero'}
    class="relative flex min-h-dvh items-center overflow-hidden"
  >
    <!-- Desktop video background -->
    <video
      autoplay
      muted
      loop
      playsinline
      poster={cms.heroImage}
      class="absolute inset-0 h-full w-full object-cover hidden md:block"
      aria-hidden="true"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <!-- Mobile: poster image -->
    <img
      src={cms.heroImage}
      alt=""
      width="800"
      height="1066"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
      loading="eager"
      aria-hidden="true"
    />
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-ink/70 via-ink/55 to-ink/75"></div>

    <!-- Content -->
    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
      <div class="max-w-2xl">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-widest text-white/60">
          {isFr ? "Ottawa's #1 — Nettoyage Extérieur" : "Ottawa's #1 — Exterior Cleaning"}
        </p>
        <h1
          class="font-heading font-semibold text-white"
          style="font-size: clamp(2.25rem, 6vw, 4.5rem); line-height: 1.08; letter-spacing: -0.02em;"
        >
          {isFr ? cms.heroHeadlineFr : cms.heroHeadlineEn}
        </h1>
        <p class="mt-6 text-lg text-white/75 sm:text-xl" style="max-width: 42ch;">
          {isFr ? cms.heroSubtitleFr : cms.heroSubtitleEn}
        </p>

        <!-- CTA row -->
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href={`/${locale}/contact`}
            class="touch-target inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-medium text-brand shadow-sm transition-colors duration-200 hover:bg-surface-soft active:scale-95 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand"
          >
            {t.cta.freeQuote}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a
            href={`tel:${s.phoneLink}`}
            class="touch-target inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 px-6 py-3 text-sm font-medium text-white backdrop-blur-sm transition-colors duration-200 hover:bg-white/20 active:scale-95 focus-visible:ring-2 focus-visible:ring-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {s.phone}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <div class="flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="text-xs font-medium text-white/90">{t.trust.insured}</span>
          </div>
          <a
            href={s.googleUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="touch-target flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 backdrop-blur-sm transition-colors hover:bg-white/20 focus-visible:ring-2 focus-visible:ring-white"
            aria-label={isFr ? `${cms.googleReviewCount} avis Google — ouvre une nouvelle fenêtre` : `${cms.googleReviewCount} Google reviews — opens new window`}
          >
            <div class="flex gap-0.5 text-amber-400" role="img" aria-label="5 out of 5 stars">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="text-xs font-medium text-white/90">{cms.googleRating} · {cms.googleReviewCount} {isFr ? cms.statsRatingFr : cms.statsRatingEn}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CORAL SIGNATURE CARD — Full-bleed differentiator -->
  <!-- ============================================================ -->
  <section class="bg-signature-coral" aria-label={isFr ? "Notre différence" : "Our difference"}>
    <div class="mx-auto max-w-7xl px-6 py-16 lg:flex lg:items-center lg:justify-between lg:gap-16 lg:py-20 lg:px-8">
      <div class="max-w-xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-white/60 mb-3">
          {isFr ? "Pourquoi All Star" : "Why All Star"}
        </p>
        <h2
          class="font-heading font-semibold text-white"
          style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.02em;"
        >
          {isFr ? "Ottawa aime un extérieur propre. Nous l'assurons." : "Ottawa loves a clean exterior. We make it happen."}
        </h2>
        <p class="mt-4 text-base text-white/75 leading-relaxed" style="max-width: 44ch;">
          {isFr
            ? "Service local, équipement professionnel, garantie de satisfaction — chaque fois."
            : "Local service, professional equipment, satisfaction guarantee — every single time."}
        </p>
      </div>
      <div class="mt-8 flex flex-col gap-3 lg:mt-0 lg:shrink-0">
        <a
          href={`/${locale}/contact`}
          class="touch-target inline-flex items-center justify-center gap-2 rounded-lg border border-white/40 bg-white/15 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-white/25 active:scale-95 focus-visible:ring-2 focus-visible:ring-white"
        >
          {t.cta.freeQuote}
        </a>
        <a
          href={`/${locale}/about`}
          class="touch-target inline-flex items-center justify-center gap-1 text-sm font-medium text-white/70 transition-colors hover:text-white"
        >
          {isFr ? "Notre histoire" : "Our story"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- USP SECTION — White canvas, image + feature cards -->
  <!-- ============================================================ -->
  <section
    aria-label={isFr ? 'Pourquoi nous choisir' : 'Why choose us'}
    class="bg-canvas"
    style="padding-top: var(--space-section); padding-bottom: var(--space-section);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
        <!-- Image -->
        <div class="overflow-hidden rounded-lg shadow-md">
          <img
            src={cms.teamImage}
            alt={isFr ? "L'équipe All Star Cleaning au travail à Ottawa" : 'All Star Cleaning crew at work in Ottawa'}
            width="800"
            height="600"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>

        <!-- Text + cards -->
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-widest text-brand mb-3">
            {isFr ? "Notre approche" : "Our approach"}
          </p>
          <h2
            class="font-heading font-semibold text-ink"
            style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.15; letter-spacing: -0.02em;"
          >
            {isFr ? 'Pourquoi choisir All Star ?' : 'Why choose All Star?'}
          </h2>
          <p class="mt-4 text-base text-ink/60 leading-relaxed" style="max-width: 44ch;">
            {isFr
              ? "Expertise locale, équipement professionnel et garantie sans tracas."
              : 'Local expertise, professional gear, and a hassle-free guarantee.'}
          </p>

          <div class="mt-8 flex flex-col gap-3">
            <div class="flex items-start gap-4 rounded-lg border border-hairline bg-surface-soft p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-brand/10 text-brand">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-ink">{isFr ? "Expertise Locale" : "Local Expertise"}</h3>
                <p class="mt-1 text-sm text-ink/60 leading-relaxed">{isFr ? "Spécialistes des hivers ottawiens — gouttières, vitres et revêtements." : "Specialists in Ottawa winters — gutters, windows, siding."}</p>
              </div>
            </div>
            <div class="flex items-start gap-4 rounded-lg border border-hairline bg-surface-soft p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-brand/10 text-brand">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-ink">{isFr ? "Équipement Professionnel" : "Professional Equipment"}</h3>
                <p class="mt-1 text-sm text-ink/60 leading-relaxed">{isFr ? "Aspirateurs spécialisés, caméras de gouttières, laveuses haute pression sécurisées." : "Specialized vacuums, gutter cameras, safe pressure washers."}</p>
              </div>
            </div>
            <div class="flex items-start gap-4 rounded-lg border border-hairline bg-surface-soft p-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-brand/10 text-brand">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-ink">{isFr ? "Garantie Sans Tracas" : "Hassle-Free Guarantee"}</h3>
                <p class="mt-1 text-sm text-ink/60 leading-relaxed">{isFr ? "100% satisfaction promise. Pas satisfait ? Nous revenons sans frais." : "100% satisfaction. Not happy? We come back at no charge."}</p>
              </div>
            </div>
          </div>

          <a href={`/${locale}/contact`} class="touch-target mt-6 inline-flex items-center gap-2 text-sm font-medium text-brand transition-colors hover:text-brand-active focus-visible:ring-2 focus-visible:ring-brand rounded-md">
            {t.cta.freeQuote}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SERVICES GRID — White canvas -->
  <!-- ============================================================ -->
  <section
    aria-label={isFr ? 'Nos services' : 'Our services'}
    class="border-t border-hairline bg-canvas"
    style="padding-top: var(--space-section); padding-bottom: var(--space-section);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-12 flex items-end justify-between gap-6">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-widest text-brand mb-2">
            {isFr ? "Ce que nous faisons" : "What we do"}
          </p>
          <h2
            class="font-heading font-semibold text-ink"
            style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.15; letter-spacing: -0.02em;"
          >
            {isFr ? 'Nos Services' : 'Our Services'}
          </h2>
        </div>
        <a href={`/${locale}/services`} class="touch-target shrink-0 rounded-md border border-hairline px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-brand hover:text-brand focus-visible:ring-2 focus-visible:ring-brand hidden sm:inline-flex">
          {isFr ? "Tous les services" : "All services"}
        </a>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => {
          const imgSrc = service.image || `/images/${service.slug}.jpg`;
          const isFeatured = i === 0;
          return (
            <a
              href={`/${locale}/services/${service.slug}`}
              class:list={[
                'group relative overflow-hidden rounded-lg transition-transform duration-200 hover:scale-[1.01] hover:shadow-lg',
                isFeatured ? 'md:col-span-2 lg:col-span-2' : '',
              ]}
              style={isFeatured ? 'aspect-ratio: 16/7' : 'aspect-ratio: 4/3'}
            >
              <img
                src={imgSrc}
                alt={isFr ? service.frName : service.name}
                width="800"
                height="600"
                class:list={['absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105', serviceObjectPosition[service.slug] ?? 'object-center']}
                loading={i < 2 ? 'eager' : 'lazy'}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-ink/75 via-ink/30 to-transparent" />
              <div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
                <h3 class="font-heading text-base font-semibold text-white">
                  {isFr ? service.frName : service.name}
                </h3>
                <p class="mt-1 line-clamp-2 text-sm text-white/70">
                  {isFr ? service.frDescription : service.description}
                </p>
                <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-white/80 group-hover:text-white transition-colors">
                  {t.ui.learnMore}
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href={`/${locale}/services`} class="touch-target inline-flex rounded-md border border-hairline px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-brand hover:text-brand focus-visible:ring-2 focus-visible:ring-brand">
          {isFr ? "Tous les services" : "All services"}
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- DARK NAVY SIGNATURE CARD — CTA conversion section -->
  <!-- ============================================================ -->
  <section class="bg-surface-dark" aria-label={isFr ? 'Contactez-nous' : 'Contact us'}>
    <div class="mx-auto max-w-7xl px-6 py-16 text-center lg:py-20 lg:px-8">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-white/40 mb-4">
        {isFr ? "Passons à l'action" : "Let's get started"}
      </p>
      <h2
        class="font-heading font-semibold text-white mx-auto"
        style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.02em; max-width: 20ch;"
      >
        {isFr ? cms.ctaHeadlineFr : cms.ctaHeadlineEn}
      </h2>
      <p class="mt-4 text-base text-white/60 mx-auto" style="max-width: 44ch;">
        {isFr ? cms.ctaSubtitleFr : cms.ctaSubtitleEn}
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href={`/${locale}/contact`}
          class="touch-target inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-brand-active active:scale-95 focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-surface-dark"
        >
          {t.cta.freeQuote}
        </a>
        <a
          href={`tel:${s.phoneLink}`}
          class="touch-target inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-white/15 active:scale-95 focus-visible:ring-2 focus-visible:ring-white"
        >
          {s.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TESTIMONIAL — Cream signature card -->
  <!-- ============================================================ -->
  <section class="bg-signature-cream" aria-label={isFr ? 'Témoignage client' : 'Customer testimonial'}>
    <div class="mx-auto max-w-3xl px-6 py-16 text-center lg:py-20 lg:px-8">
      <div class="flex justify-center gap-0.5 text-amber-500 mb-6" role="img" aria-label="5 out of 5 stars">
        {[...Array(5)].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
      </div>
      <blockquote
        class="font-heading font-medium text-ink"
        style="font-size: clamp(1.125rem, 2.5vw, 1.5rem); line-height: 1.5; max-width: 38ch; margin: 0 auto;"
      >
        &ldquo;{isFr
          ? "Service exceptionnel ! Ils ont nettoyé nos gouttières et fenêtres en une seule visite. L'équipe était ponctuelle, professionnelle et a tout laissé impeccable."
          : "Outstanding service! They cleaned our gutters and windows in a single visit. The crew was on time, professional, and left everything spotless."}&rdquo;
      </blockquote>
      <p class="mt-6 text-sm text-ink/60">
        — Sarah Mitchell, {isFr ? 'Nettoyage de gouttières · Ottawa' : 'Gutter Cleaning · Ottawa'}
      </p>
      <p class="mt-2 text-xs text-ink/40">
        {isFr ? `${cms.googleReviewCount} avis Google vérifiés` : `${cms.googleReviewCount} verified Google reviews`}
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- HOW IT WORKS — White canvas, 3-step -->
  <!-- ============================================================ -->
  <section
    aria-label={isFr ? 'Comment ça marche' : 'How it works'}
    class="bg-canvas border-t border-hairline"
    style="padding-top: var(--space-section); padding-bottom: var(--space-section);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-brand mb-2">
          {isFr ? "Simple & rapide" : "Simple & fast"}
        </p>
        <h2
          class="font-heading font-semibold text-ink"
          style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.15; letter-spacing: -0.02em;"
        >
          {isFr ? 'Comment Ça Marche' : 'How It Works'}
        </h2>
        <p class="mt-4 text-base text-ink/60 mx-auto" style="max-width: 44ch;">
          {isFr ? "Un extérieur impeccable en trois étapes." : 'A spotless exterior in three simple steps.'}
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {[
          {
            num: '1',
            en: { h: 'Get a Free Quote', p: 'Call or fill out our form. We respond within 24 hours with a no-obligation estimate.' },
            fr: { h: 'Obtenez un Devis', p: 'Appelez ou remplissez notre formulaire. Réponse sous 24 heures.' },
          },
          {
            num: '2',
            en: { h: 'We Do the Work', p: 'Our crew arrives on time with premium equipment and treats your home with care.' },
            fr: { h: 'Nous Faisons le Travail', p: "Notre équipe arrive à l'heure avec de l'équipement professionnel." },
          },
          {
            num: '3',
            en: { h: 'Enjoy the Result', p: 'Sparkling windows, clean gutters, fresh driveways — 100% satisfaction guaranteed.' },
            fr: { h: 'Profitez du Résultat', p: 'Vitres étincelantes, gouttières propres — satisfaction garantie à 100%.' },
          },
        ].map((step) => (
          <div class="text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <span class="font-heading text-2xl font-semibold">{step.num}</span>
            </div>
            <h3 class="mt-5 font-heading text-base font-semibold text-ink">
              {isFr ? step.fr.h : step.en.h}
            </h3>
            <p class="mt-2 text-sm text-ink/60 leading-relaxed mx-auto" style="max-width: 28ch;">
              {isFr ? step.fr.p : step.en.p}
            </p>
          </div>
        ))}
      </div>

      <div class="mt-12 overflow-hidden rounded-lg shadow-sm">
        <img
          src={cms.beforeAfterImage}
          alt={isFr ? 'Résultats avant et après le nettoyage extérieur' : 'Before and after exterior cleaning results'}
          width="1344"
          height="480"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FOREST SIGNATURE CARD — Service areas -->
  <!-- ============================================================ -->
  <section class="bg-signature-forest" aria-label={isFr ? 'Zones desservies' : 'Service areas'}>
    <div class="mx-auto max-w-7xl px-6 py-16 lg:flex lg:items-center lg:justify-between lg:gap-16 lg:py-20 lg:px-8">
      <div class="max-w-xl">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-white/50 mb-3">
          {isFr ? "44 secteurs" : "44 communities"}
        </p>
        <h2
          class="font-heading font-semibold text-white"
          style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1; letter-spacing: -0.02em;"
        >
          {isFr ? "Nous desservons tout Ottawa." : "Serving all of Ottawa."}
        </h2>
        <p class="mt-4 text-base text-white/70 leading-relaxed" style="max-width: 44ch;">
          {isFr
            ? "Barrhaven, Kanata, Nepean, Gloucester, Orléans, Stittsville, Manotick et plus encore."
            : "Barrhaven, Kanata, Nepean, Gloucester, Orleans, Stittsville, Manotick, and more."}
        </p>
      </div>
      <div class="mt-8 flex flex-col items-start gap-3 lg:mt-0 lg:shrink-0">
        <a
          href={`/${locale}/area`}
          class="touch-target inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-white/20 active:scale-95 focus-visible:ring-2 focus-visible:ring-white"
        >
          {isFr ? "Voir tous les secteurs" : "See all service areas"}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- LIGHT CTA BAND — Near-footer conversion -->
  <!-- ============================================================ -->
  <section class="bg-surface-strong" aria-label={isFr ? "Obtenez votre devis" : "Get your quote"}>
    <div class="mx-auto max-w-7xl px-6 py-14 text-center lg:px-8">
      <h2
        class="font-heading font-semibold text-ink"
        style="font-size: clamp(1.25rem, 3vw, 2rem); line-height: 1.2; letter-spacing: -0.01em;"
      >
        {isFr ? "Prêt pour un extérieur impeccable ?" : "Ready for a spotless exterior?"}
      </h2>
      <p class="mt-3 text-sm text-ink/60">
        {isFr ? "Réponse sous 24 heures · Sans engagement" : "24hr response · No obligation"}
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={`/${locale}/contact`}
          class="touch-target inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-brand-active active:scale-95 focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
        >
          {t.cta.freeQuote}
        </a>
        <a
          href={`tel:${s.phoneLink}`}
          class="touch-target inline-flex items-center gap-2 rounded-lg border border-hairline bg-canvas px-6 py-3 text-sm font-medium text-ink transition-colors hover:border-brand hover:text-brand active:scale-95 focus-visible:ring-2 focus-visible:ring-brand"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {s.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
