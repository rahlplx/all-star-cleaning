---
import PageLayout from '@/layouts/PageLayout.astro';
import { services, getServiceBySlug } from '@/data/services';
import { getServiceSchema, getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    services.map((service) => ({
      params: { locale, serviceSlug: service.slug },
      props: { service, locale: locale as 'en' | 'fr' },
    }))
  );
}

const { service, locale } = Astro.props;
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Services', frLabel: 'Services', href: `/${locale}/services` },
  { label: service.name, frLabel: service.frName, href: `/${locale}/services/${service.slug}` },
];
const serviceSchema = getServiceSchema(service, locale, `https://allstarcleaning.ca/${locale}/services/${service.slug}`);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const altSlug = isFr ? service.frSlug : service.slug;
---

<PageLayout
  title={isFr ? service.frMetaTitle : service.metaTitle}
  description={isFr ? service.frMetaDescription : service.metaDescription}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? service.frName : service.name}
  heroSubtitle={isFr ? service.frDescription : service.description}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/services/${altSlug}` }]}
  schema={[serviceSchema, breadcrumbSchema]}
>
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <h2 class="font-heading text-2xl font-bold text-navy">{isFr ? 'Ce qui est inclus' : "What's Included"}</h2>
      <ul class="mt-4 space-y-3">
        {(isFr ? service.frFeatures : service.features).map((feature) => (
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground">{feature}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8">
        <h2 class="font-heading text-2xl font-bold text-navy">{isFr ? 'Pourquoi choisir All Star Cleaning?' : 'Why Choose All Star Cleaning?'}</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-border bg-off-white p-4"><h3 class="font-medium text-navy">{isFr ? 'Résultats Garantis' : 'Guaranteed Results'}</h3><p class="mt-1 text-sm text-muted">{isFr ? 'Satisfaction garantie à 100% sur chaque travail.' : '100% satisfaction guaranteed on every job.'}</p></div>
          <div class="rounded-lg border border-border bg-off-white p-4"><h3 class="font-medium text-navy">{isFr ? 'Équipement Professionnel' : 'Professional Equipment'}</h3><p class="mt-1 text-sm text-muted">{isFr ? 'Technologie de pointe pour des résultats supérieurs.' : 'Cutting-edge technology for superior results.'}</p></div>
          <div class="rounded-lg border border-border bg-off-white p-4"><h3 class="font-medium text-navy">{isFr ? 'Équipe Expérimentée' : 'Experienced Team'}</h3><p class="mt-1 text-sm text-muted">{isFr ? 'Techniciens formés et assurés.' : 'Trained and insured technicians.'}</p></div>
          <div class="rounded-lg border border-border bg-off-white p-4"><h3 class="font-medium text-navy">{isFr ? 'Devis Gratuit' : 'Free Quotes'}</h3><p class="mt-1 text-sm text-muted">{isFr ? 'Estimations transparentes sans obligation.' : 'Transparent estimates with no obligation.'}</p></div>
        </div>
      </div>
    </div>
    <div class="lg:col-span-1">
      <div class="sticky top-24 rounded-xl border border-border bg-card p-6 shadow-md">
        <h3 class="font-heading text-xl font-bold text-navy">{isFr ? 'Obtenez un Devis' : 'Get a Quote'}</h3>
        <p class="mt-2 text-sm text-muted">{isFr ? service.frCta : service.cta}</p>
        <a href={`/${locale}/contact?service=${service.slug}`} class="mt-4 block rounded-full bg-teal px-6 py-3 text-center text-sm font-semibold text-white shadow-md transition-all hover:bg-teal-dark hover:shadow-lg">{isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}</a>
        <div class="mt-4 border-t border-border pt-4 text-center text-sm text-muted"><a href="tel:+16135550199" class="font-medium text-teal hover:text-teal-dark">(613) 555-0199</a></div>
      </div>
    </div>
  </div>
</PageLayout>
