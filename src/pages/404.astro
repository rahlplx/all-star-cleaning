---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | All Star Cleaning Ottawa"
  description="The page you're looking for doesn't exist."
  locale="en"
  noindex={true}
>
  <section class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="font-heading text-6xl font-bold text-navy">404</h1>
    <p class="mt-4 text-lg text-muted">The page you're looking for doesn't exist.</p>
    <a href="/en" class="mt-8 inline-flex items-center rounded-full bg-teal-dark px-8 py-3 text-lg font-semibold text-white shadow-lg transition-all hover:bg-navy hover:shadow-xl">Go Home</a>
  </section>
</BaseLayout>
